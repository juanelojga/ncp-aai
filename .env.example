# Docker Compose mounts host folders into the container. Keep these `/app/...`
# paths unless you are intentionally running the backend outside Compose.
APP_DATA_DIR=/app/data
APP_VAULT_DIR=/app/vault
APP_INBOX_DIR=/app/inbox
APP_ARTIFACT_DIR=/app/artifacts
DATABASE_URL=sqlite:////app/data/app.db
CHROMA_DIR=/app/data/chroma
CODEX_OUTPUT_DIR=/app/inbox/codex
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Future programmatic providers, not used by the MVP Codex ingestion path.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
